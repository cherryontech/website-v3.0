---
import "../styles/global.css";
import { tv } from 'tailwind-variants';


const { type } = Astro.props

const headerStyle = tv({
    base: 'font-lato text-5xl desktop:text-6xl',
    variants: {
        type: {
            normal: "font-normal",
            bold: "font-semibold desktop:font-bold"
        }
    }
});

const headerType = headerStyle({ type })
---

<h1 class={headerType}>
    <slot/>
</h1>