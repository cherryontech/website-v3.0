---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

const variants = [
  { label: 'Primary', variant: 'primary' },
  { label: 'Secondary', variant: 'secondary' },
  { label: 'Stroke', variant: 'stroke' },
  { label: 'Link', variant: 'link' },
];

const states = [
  { label: 'Default', className: '' },
  { label: 'Hover', className: 'is-hover' },
  { label: 'Active', className: 'is-active' },
  { label: 'Disabled', className: 'is-disabled', disabled: true },
];

const sections = [
  { title: 'Large', size: 'large', text: 'Large Button', hasIcon: false, iconOnly: false },
  { title: 'Large with icon', size: 'large', text: 'Large Button', hasIcon: true, iconOnly: false },
  { title: 'Small', size: 'small', text: 'Small Button', hasIcon: false, iconOnly: false },
  { title: 'Icon only', size: 'large', text: 'Open menu', hasIcon: true, iconOnly: true },
];
---

<Layout>
  <main class="button-samples">
    <h1>Button Samples</h1>

    {sections.map((section) => (
      <section class="sample-section" aria-labelledby={`section-${section.title.toLowerCase().replaceAll(' ', '-')}`}>
        <h2 id={`section-${section.title.toLowerCase().replaceAll(' ', '-')}`}>{section.title}</h2>

        <div class="sample-grid sample-header" aria-hidden="true">
          <div></div>
          {variants.map((variant) => <strong>{variant.label}</strong>)}
        </div>

        {states.map((state) => (
          <div class="sample-grid">
            <strong>{state.label}</strong>

            {variants.map((variant) => (
              <Button
                variant={variant.variant}
                size={section.size}
                state={state.className.replace('is-', '') || 'default'}
                disabled={state.disabled}
                href={variant.variant === 'link' ? '#' : undefined}
                icon={section.hasIcon ? 'arrow-right' : undefined}
                iconOnly={section.iconOnly}
                label={section.text}
              >
                {section.text}
              </Button>
            ))}
          </div>
        ))}
      </section>
    ))}
  </main>
</Layout>

<style>
  .button-samples {
    color: var(--color-text-primary);
    margin: 0 auto;
    max-width: 1120px;
    padding: 48px 32px;
  }

  .button-samples h1 {
    font-size: 32px;
    line-height: 1.2;
    margin: 0 0 32px;
  }

  .sample-section {
    margin-top: 40px;
  }

  .sample-section h2 {
    background-color: var(--color-background-accent-blue-light);
    font-size: 20px;
    line-height: 1.2;
    margin: 0 0 20px;
    padding: 10px 16px;
    text-align: center;
  }

  .sample-grid {
    align-items: center;
    column-gap: 28px;
    display: grid;
    grid-template-columns: 100px repeat(4, minmax(140px, 1fr));
    min-height: 64px;
  }

  .sample-header {
    min-height: 32px;
  }

  .sample-grid > strong {
    font-size: 16px;
  }
</style>
